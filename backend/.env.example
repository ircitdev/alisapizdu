PORT=3000
CORS_ORIGIN=*
NODE_ENV=development

# Yandex Cloud (YandexART)
YANDEX_FOLDER_ID=your-folder-id
YANDEX_API_KEY=your-api-key

# SMTP (для email-уведомлений по invite-ссылкам)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=notify@yourdomain.ru
SMTP_PASS=app-password
SMTP_FROM=Алиса покажи пизду <notify@yourdomain.ru>
